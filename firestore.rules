rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /profiles/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['firstName','lastName','displayName','avatarUrl','designation','specializationId','hospital','mobile','bio','credentials','createdAt','updatedAt']);
      allow update: if isOwner(uid);
    }

    match /users/{uid}/bookmarks/{caseId} {
      allow read, create, delete: if isOwner(uid);
    }

    match /users/{uid}/settings/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /cases/{caseId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['caseNumber','title','authorUid','authorName','authorAvatar','specializationId','category','description','urgent','diseaseTags','caseQuote','status','coverImage','aiReportId','viewsCount','commentsCount','createdAt','updatedAt']);
      allow update: if signedIn()
        && (resource.data.authorUid == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['viewsCount','commentsCount','aiReportId','coverImage']));
      allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['caseId','authorUid','authorName','authorAvatar','text','attachmentName','createdAt']);
      allow update: if isOwner(resource.data.authorUid);
      allow delete: if isOwner(resource.data.authorUid);
    }

    match /images/{imageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['caseId','authorUid','storagePath','thumbnailPath','displayURL','thumbnailURL','width','height','size','createdAt']);
      allow delete: if isOwner(resource.data.authorUid);
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /specializations/{specId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /aiReports/{reportId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['id','caseId','createdAt','model','aiResponse','structured']);
    }
  }
}
